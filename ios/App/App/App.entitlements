<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- APNs environment. Xcode flips this to "development" for debug builds automatically. -->
	<key>aps-environment</key>
	<string>production</string>

	<!--
		Critical Alerts: this is what makes a Freddy "Need you" punch through the ringer switch
		and Focus/Do-Not-Disturb. It REQUIRES Apple's approval — request it at
		https://developer.apple.com/contact/request/notifications-critical-alerts-entitlement/
		(justification text is in mobile/README.md). Until it's granted, builds that include this
		key will fail to sign; comment it out to build a non-critical TestFlight build in the meantime.
	-->
	<key>com.apple.developer.usernotifications.critical-alerts</key>
	<true/>
</dict>
</plist>
