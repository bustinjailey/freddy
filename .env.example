# Copy to ".env" for local dev, or set these in the systemd EnvironmentFile on the
# webapps LXC (/opt/apps/freddy/env). All are read at runtime.

# Port the Node server binds (the webapps LXC convention puts this in ./env).
PORT=3001

# adapter-node needs the public origin so SvelteKit's CSRF check accepts POSTs
# that arrive through the reverse proxy.
ORIGIN=https://freddy.bustinjailey.org

# VAPID keys for Web Push. Generate once:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:bustinjailey@gmail.com

# The two parents shown on the "who are you?" screen. Comma-separated, exactly two.
FREDDY_IDENTITIES=Justin,Mom

# Where push subscriptions are persisted (relative to the working directory).
FREDDY_DATA_DIR=data

# Escalation: the request tiles re-fire the notification on the other phone until it's
# acknowledged (app opened, or notification tapped/dismissed). Tune the cadence here.
#   FREDDY_REPEAT_INTERVAL_SEC  seconds between nudges (default 30, clamped 5..600)
#   FREDDY_REPEAT_MAX           how many nudges before giving up (default 6 ≈ 3 min; 0 = off)
FREDDY_REPEAT_INTERVAL_SEC=30
FREDDY_REPEAT_MAX=6

# --- Native iOS critical alerts (optional) -------------------------------------------------
# Only needed if the Capacitor app (mobile/) is in use. Leave unset and the server just skips
# the native iOS channel — PWA web push is unaffected. Get these from your Apple developer
# account: App Store Connect -> Users & Access -> Integrations -> Keys -> enable APNs, download
# the .p8 once. See mobile/README.md for the full provisioning checklist (incl. the Critical
# Alerts entitlement request).
#   APNS_KEY        the .p8 file *contents* (multi-line; or use APNS_KEY_PATH instead)
#   APNS_KEY_PATH   path to the .p8 file (alternative to APNS_KEY)
APNS_KEY=
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=org.bustinjailey.freddy
# Set to "false" to use the APNs sandbox (debug builds); anything else = production.
APNS_PRODUCTION=true

# Build-time only: URL the native WebView shell loads. Defaults to https://freddy.bustinjailey.org.
# FREDDY_NATIVE_URL=https://freddy.bustinjailey.org
